# ============================================
# Glassypage — environment configuration
# Copy to ".env" (next to docker-compose.yml) and adjust.
#   cp .env.example .env
# ============================================

# Host port the dashboard is served on → http://localhost:<PORT>
PORT=3000

# Run the container as this host user so bind-mounted files
# (config.json, plugins/, scratchpad.txt) stay writable.
# Find your values with:  id -u   and   id -g
PUID=1000
PGID=1000

# Timezone for the clock / uptime (e.g. Europe/Budapest, America/New_York)
TZ=UTC

# GID of the host "docker" group so the Docker widget can use the socket.
# Find it with:  getent group docker | cut -d: -f3
DOCKER_GID=999
